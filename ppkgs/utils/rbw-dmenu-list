# wrapper around rbw

st -c st_floating -e rbw list

if [ "$1" == "2fa" ]; then
	resp=$(rbw list | dmenu)
else
	resp=$(rbw list | dmenu)
fi

if [ "$1" == "2fa" ]; then
	rbw code "$resp" | xclip -in -selection clipboard
else
	rbw get "$resp" | xclip -in -selection clipboard
fi

# if we don't, then for some reason it'll just continue running and eat up 100% of CPU
# that's bad software design, so we'll answer with something worse
pkill pinentry

sleep 15
echo "cleared" | xclip -in -selection clipboard

