# wrapper around rbw

st -c st_floating -e rbw list

resp=$(rbw list | dmenu)

if [ -z "$resp" ]; then
    exit 1
fi

case "$1" in
    "username")
	rbw get "$resp" --full | \
    	    grep "Username: " | \
    	    awk -F': ' '{print $2}' | \
    	    xclip -in -selection clipboard
	;;
    "2fa")
	rbw code "$resp" | xclip -in -selection clipboard
	;;
    *)
	rbw get "$resp" | xclip -in -selection clipboard
	;;
esac
clipboard_immediate=$(xclip -out -selection clipboard)
	
# if we don't, then for some reason it'll just continue running and eat up 100% of CPU
# that's bad software design, so we'll answer with something worse
pkill pinentry

sleep 15
current_clipboard=$(xclip -out -selection clipboard)
if [ "$current_clipboard" = "$clipboard_immediate" ]; then
    echo "cleared" | xclip -in -selection clipboard
fi
